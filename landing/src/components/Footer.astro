---
const year = new Date().getFullYear()
---

<footer class="footer">
  <hr class="rule wrap-rule" />
  <div class="wrap footer__inner">
    <a class="brand" href="#top" aria-label="PitchPilot home">
      <img src="/logo.svg" width="28" height="28" alt="" />
      <span class="brand__word">Pitch<span class="brand__alt">Pilot</span></span>
    </a>

    <nav class="footer__links" aria-label="Footer">
      <a href="#problem">What it hears</a>
      <a href="#how">How it works</a>
      <a href="#scorecard">Scorecard</a>
    </nav>

    <p class="footer__tag mono">Pitch like the room is already skeptical. © {year}</p>
  </div>
</footer>

<style>
  .footer { padding-bottom: 2.5rem; }
  .footer__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1.2rem;
    padding-top: 2.2rem;
  }
  .brand { display: inline-flex; align-items: center; gap: 0.55rem; text-decoration: none; }
  .brand__word { font-weight: 700; font-size: 1.05rem; color: var(--navy); }
  .brand__alt { color: var(--orange); }

  .footer__links { display: flex; gap: 1.6rem; font-size: 0.9rem; }
  .footer__links a { color: var(--muted); text-decoration: none; transition: color 160ms; }
  .footer__links a:hover { color: var(--orange); }

  .footer__tag { font-size: 0.76rem; color: var(--muted); }

  .wrap-rule {
    max-width: var(--maxw);
    margin-inline: auto;
    width: calc(100% - 2 * var(--gut));
  }

  @media (max-width: 640px) {
    .footer__inner { flex-direction: column; align-items: flex-start; }
  }
</style>
